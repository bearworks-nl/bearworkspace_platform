# Copy this to .env and fill in your values

SECRET_KEY=your-secret-key-here-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost 127.0.0.1

# Database (PostgreSQL)
DB_NAME=workspace_manager
DB_USER=workspace_manager
DB_PASSWORD=workspace_manager
DB_HOST=localhost
DB_PORT=5432

# Celery (use CELERY_TASK_ALWAYS_EAGER=True for local dev without Redis)
CELERY_TASK_ALWAYS_EAGER=True
# REDIS_URL=redis://localhost:6379/0

# Mollie
MOLLIE_API_KEY=test_xxxxxxxxxxxxxxxxxxxxxx

# Email (console backend for dev, configure SMTP for production)
# EMAIL_HOST=smtp.yourprovider.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=you@company.com
# EMAIL_HOST_PASSWORD=yourpassword
# EMAIL_USE_TLS=True
