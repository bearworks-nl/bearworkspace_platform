# Django
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_NAME=bearworkspace_db
DB_USER=bearworkspace
DB_PASSWORD=bearworkspace
DB_HOST=localhost
DB_PORT=5432

# Redis / Celery
# REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/1
REDIS_URL=memory://
CELERY_BROKER_URL = env("CELERY_BROKER_URL", default="redis://localhost:6379/0")
CELERY_RESULT_BACKEND = env("CELERY_RESULT_BACKEND", default="redis://localhost:6379/1")
CELERY_TASK_ALWAYS_EAGER = True        # run tasks inline, no worker needed
CELERY_TASK_EAGER_PROPAGATES = True    # surface errors immediately

# Email (SendGrid)
SENDGRID_API_KEY=your-sendgrid-key
DEFAULT_FROM_EMAIL=noreply@bearworks.nl

# Mollie
MOLLIE_API_KEY=test_your-mollie-test-key
MOLLIE_WEBHOOK_URL=https://yourdomain.com/billing/webhook/mollie/

# Microsoft Graph API (for product integrations)
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# Azure Storage (production static/media files)
AZURE_ACCOUNT_NAME=
AZURE_ACCOUNT_KEY=
AZURE_STATIC_CONTAINER=static
